# Compose ports
L2BG_FRONTEND_PORT=5173
L2BG_BACKEND_PORT=8080
L2BG_POSTGRES_PORT=5432

# Frontend -> backend wiring
VITE_L2BG_API_BASE_URL=/api
L2BG_VITE_PROXY_TARGET=http://backend:8080
L2BG_PUBLIC_WS_URL=ws://localhost:5173/api/v1/gameplay/ws

# Backend runtime
L2BG_BACKEND_ADDR=0.0.0.0:8080
L2BG_DATABASE_URL=postgres://l2bg:l2bg_local_dev@postgres:5432/l2bg?sslmode=disable
L2BG_ALLOWED_ORIGINS=http://localhost:5173
L2BG_ACCESS_TOKEN_TTL=2h
L2BG_AUTH_RATE_LIMIT_MAX_ATTEMPTS=
L2BG_AUTH_RATE_LIMIT_WINDOW=
L2BG_ATTACH_RATE_LIMIT_MAX_ATTEMPTS=
L2BG_ATTACH_RATE_LIMIT_WINDOW=
L2BG_INTERNAL_AUDIT_ENABLED=
L2BG_INTERNAL_AUDIT_TOKEN=
L2BG_TEST_DATABASE_URL=
L2BG_SERVER_INSTANCE_ID=backend-compose-1
L2BG_SESSION_LEASE_DURATION=30s
L2BG_SESSION_LEASE_RENEW_INTERVAL=10s
L2BG_SESSION_ATTACH_TOKEN_TTL=5m
L2BG_AUTH_SOCIAL_GOOGLE_CLIENT_ID=
L2BG_AUTH_SOCIAL_GOOGLE_CLIENT_SECRET=
L2BG_AUTH_SOCIAL_GOOGLE_REDIRECT_URL=
L2BG_AUTH_SOCIAL_FACEBOOK_CLIENT_ID=
L2BG_AUTH_SOCIAL_FACEBOOK_CLIENT_SECRET=
L2BG_AUTH_SOCIAL_FACEBOOK_REDIRECT_URL=

# PostgreSQL
L2BG_POSTGRES_DB=l2bg
L2BG_POSTGRES_USER=l2bg
L2BG_POSTGRES_PASSWORD=l2bg_local_dev
